TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Neon Postgres (https://neon.tech) — untuk simpan kredit user secara persistent
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ToyyibPay (https://toyyibpay.com)
TOYYIBPAY_SECRET_KEY=your_toyyibpay_secret_key
TOYYIBPAY_CATEGORY_CODE=your_toyyibpay_category_code
TOYYIBPAY_BASE_URL=https://toyyibpay.com
# ^ guna https://dev.toyyibpay.com untuk sandbox/testing

# URL public app kau (Railway akan bagi lepas deploy pertama, contoh:
# https://studybot-production.up.railway.app)
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Optional
FREE_STARTING_CREDITS=10
ADMIN_USER_IDS=your_telegram_user_id_here

# OpenRouter (backup terakhir kalau semua model Gemini gagal — guna Qwen/Llama, free)
# Kalau tak diisi, bot skip step ni sepenuhnya (tak error, cuma kurang backup)
OPENROUTER_API_KEY=your_openrouter_api_key_here
